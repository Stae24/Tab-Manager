{
  "manifest_version": 3,
  "name": "Opera GX Island Manager",
  "version": "1.0.0",
  "description": "Advanced tab and island manager with cloud sync and memory optimization.",
  "permissions": [
    "tabs",
    "tabGroups",
    "storage",
    "unlimitedStorage",
    "contextMenus",
    "sidePanel",
    "scripting"
  ],
  "host_permissions": [
    "*://*/*"
  ],
  "side_panel": {
    "default_path": "index.html"
  },
  "sidebar_action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "Opera GX Island Manager",
    "default_panel": "index.html"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "_favicon/*",
        "index.html",
        "assets/*"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_title": "Open Island Manager"
  },
"commands": {
    "toggle-island-manager": {
      "suggested_key": {
        "default": "Ctrl+Shift+M",
        "mac": "Command+Shift+M"
      },
      "description": "Open or focus Island Manager"
    }
  }
}